# --- SECURITY ---
# Comma-separated list of extra hosts allowed by the Vite dev server.
# Needed when exposing `pnpm dev` through a tunnel (ngrok, Cloudflare, etc.),
# otherwise Vite replies "Blocked request. This host is not allowed".
# An empty value keeps the default allow-list (localhost only) — it does NOT mean "allow all".
# Example: VITE_ALLOWED_HOSTS="my-tunnel.ngrok.io,example.com"
VITE_ALLOWED_HOSTS=

# --- API KEYS (dev tooling only, never shipped to the browser) ---
# Used by `pnpm run translate-ui` to auto-translate UI locale files via DeepSeek.
# Not prefixed with VITE_, so it is never bundled into the client.
# Get it at: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_api_key_here
